<misterromdescription>
	<name>Xevious 3D/G (World, XV32/VER.A)</name>
	<setname>xevi3dga</setname>
	<year>1995</year>
	<manufacturer>Namco</manufacturer>
	<rbf>XNSYSTEM11</rbf>

	<!-- NOTE: KEYCUS C430 implemented (keycus_id 0x05) -->
	<!-- NOTE: wave ROM 4MB - needs the >=4MB wave window core build -->
	<!-- ioctl_index 0: game program -> SDRAM 0x400000, CPU 0x1FC00000 -->
	<rom index="0" zip="xevi3dga.zip|xevi3dg.zip" md5="none">
		<interleave output="16">
			<part name="xv32vera.2l" crc="bb5c0f1b" map="01"/>
			<part name="xv32vera.2j" crc="21e20037" map="10"/>
		</interleave>
		<interleave output="16">
			<part name="xv31vera.2k" crc="3d58138e" map="01"/>
			<part name="xv31vera.2f" crc="9e8780a2" map="10"/>
		</interleave>
	</rom>
	<!-- ioctl_index 1: platform byte: bit4=1 -> Namco System 11 -->
	<rom index="1"><part>14 05</part></rom>
	<!-- ioctl_index 3: banked data ROM (16MB region) -> SDRAM 0x800000, 8x1MB CPU windows -->
	<rom index="3" zip="xevi3dga.zip|xevi3dg.zip" md5="none">
		<interleave output="16">
			<part name="xv31rom0l.ic5" crc="24e1e262" map="01"/>
			<part name="xv31rom0u.ic6" crc="cae38ef3" map="10"/>
		</interleave>
		<interleave output="16">
			<part name="xv31rom1l.ic3" crc="46b4cb72" map="01"/>
			<part name="xv31rom1u.ic8" crc="be0eb5d1" map="10"/>
		</interleave>
		<interleave output="16">
			<part name="xv31rom2l.ic4" crc="8403a277" map="01"/>
			<part name="xv31rom2u.ic7" crc="ecf70432" map="10"/>
		</interleave>
	</rom>
	<!-- ioctl_index 6: C76 sound program (SPROG) -> SDRAM 0x1800000 -->
	<rom index="6" zip="xevi3dga.zip|xevi3dg.zip" md5="none">
		<part name="xv31sprog.6d" crc="7e9fc6a0"/>
	</rom>
	<!-- ioctl_index 7: C352 wave ROM -> SDRAM 0x1840000 -->
	<rom index="7" zip="xevi3dga.zip|xevi3dg.zip" md5="none">
		<part name="xv31wave.8k" crc="14f25ddd"/>
	</rom>
	<rom index="8" zip="namcoc76.zip" md5="none">
		<!-- C76 internal BIOS (16KB) - loaded into the sound MCU at core start -->
		<part name="c76.bin"/>
	</rom>
	<!-- ioctl_index 9: EEPROM (AT28C16, 2KB). All-FF blank fill (4096 bytes -> 1024 words). -->
	<!-- No proprietary nvram ships; the game writes its own defaults on first boot.      -->
	<rom index="9">
		<part repeat="4096">FF</part>
	</rom>
</misterromdescription>
