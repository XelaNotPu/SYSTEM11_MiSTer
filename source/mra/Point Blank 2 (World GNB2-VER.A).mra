<misterromdescription>
	<name>Point Blank 2 (World, GNB2/VER.A)</name>
	<setname>ptblank2a</setname>
	<year>1999</year>
	<manufacturer>Namco</manufacturer>
	<rbf>XNSYSTEM11</rbf>

	<!-- ROM8/64 PCB: two-level rom8_64 banking (upper latch @0x1F080000), supported by the core -->
	<!-- NOTE: KEYCUS C443 implemented (keycus_id 0x09) -->
	<!-- NOTE: wave ROM 4MB - needs the >=4MB wave window core build -->
	<!-- ioctl_index 0: game program -> SDRAM 0x400000, CPU 0x1FC00000 -->
	<rom index="0" zip="ptblank2a.zip|ptblank2.zip" md5="none">
		<interleave output="16">
			<part name="gnb2vera.2l" crc="4926599d" map="01"/>
			<part name="gnb2vera.2j" crc="2aba8c09" map="10"/>
		</interleave>
		<interleave output="16">
			<part name="gnb1vera.2k" crc="e6335e4e" map="01"/>
			<part name="gnb1vera.2f" crc="2bb7eb6d" map="10"/>
		</interleave>
	</rom>
	<!-- ioctl_index 1: platform byte: bit4=1 -> Namco System 11 -->
	<rom index="1"><part>14 09</part></rom>
	<!-- ioctl_index 3: banked data ROM (32MB region) -> SDRAM 0x800000, 8x1MB CPU windows -->
	<rom index="3" zip="ptblank2a.zip|ptblank2.zip" md5="none">
		<interleave output="16">
			<part name="gnb2prg.1" crc="8a8e77c3" map="01"/>
			<part name="gnb2prg.2" crc="563edc3f" map="10"/>
		</interleave>
		<interleave output="16">
			<part name="gnb2prg.3" crc="94fbe733" map="01"/>
			<part name="gnb2prg.4" crc="1cbe79a6" map="10"/>
		</interleave>
	</rom>
	<!-- ioctl_index 6: C76 sound program (SPROG) -> SDRAM 0x1800000 -->
	<rom index="6" zip="ptblank2a.zip|ptblank2.zip" md5="none">
		<part name="gnb1vera.6d" crc="6461ae77"/>
	</rom>
	<!-- ioctl_index 7: C352 wave ROM -> SDRAM 0x1840000 -->
	<rom index="7" zip="ptblank2a.zip|ptblank2.zip" md5="none">
		<part name="gnb1wave.8k" crc="4e19d9d6"/>
	</rom>
	<rom index="8" zip="namcoc76.zip" md5="none">
		<!-- C76 internal BIOS (16KB) - loaded into the sound MCU at core start -->
		<part name="c76.bin"/>
	</rom>
	<!-- ioctl_index 9: EEPROM (AT28C16, 2KB). All-FF blank fill (4096 bytes -> 1024 words). -->
	<!-- No proprietary nvram ships; the game writes its own defaults on first boot.      -->
	<rom index="9">
		<part repeat="4096">FF</part>
	</rom>
</misterromdescription>
